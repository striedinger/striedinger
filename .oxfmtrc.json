{
  "$schema": "./node_modules/oxfmt/configuration_schema.json",
  "printWidth": 100,
  "tabWidth": 2,
  "useTabs": false,
  "semi": true,
  "singleQuote": false,
  "trailingComma": "all",
  "endOfLine": "lf",
  "sortImports": {
    "internalPattern": ["@workspace/**", "@/**"],
    "groups": [
      "type-import",
      ["value-builtin", "value-external"],
      "type-internal",
      "value-internal",
      ["type-parent", "type-sibling", "type-index"],
      ["value-parent", "value-sibling", "value-index"],
      "unknown"
    ],
    "newlinesBetween": true,
    "sortSideEffects": false
  },
  "sortTailwindcss": {
    "stylesheet": "./packages/ui/src/styles/globals.css",
    "functions": ["cn"]
  },
  "sortPackageJson": {
    "sortScripts": true
  },
  "ignorePatterns": [
    ".agents/**",
    "**/.next/**",
    "**/coverage/**",
    "**/dist/**",
    "**/node_modules/**",
    "apps/web/app/mta/data/stations.json"
  ]
}
